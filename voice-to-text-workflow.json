    {
      "parameters": {
        "jsCode": "// Receive input items\nfor (const item of $input.all()) {\n  // Check for binary data named 'data'\n  if (item.binary && item.binary.data) {\n    // Rename file and change extension\n    item.binary.data.fileName = 'voice.mp3';\n    // Change MIME type to mpeg\n    item.binary.data.mimeType = 'audio/mpeg';\n    item.binary.data.fileExtension = 'mp3';\n  }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        160
      ],
