    {
      "parameters": {
        "jsCode": "// Split long transcription text into Telegram-safe chunks (max 4000 chars)\nconst text = items[0].json.text;\nconst maxLength = 4000;\nconst parts = [];\n\nfor (let i = 0; i < text.length; i += maxLength) {\n    parts.push({ json: { chunk: text.substring(i, i + maxLength) } });\n}\n\nreturn parts;"
      },
      "type": "n8n-nodes-base.code",
